# DeadList Configuration
# Copy this file to .env and adjust values as needed.

# Volatility 3 binary path (auto-detected in Docker)
VOLATILITY_PATH=vol

# File upload directory
UPLOAD_DIR=./uploads

# SQLite database path
DATABASE_URL=sqlite+aiosqlite:///./data/deadlist.db

# Maximum upload size in GB (real RAM dumps can be 4-32 GB)
MAX_UPLOAD_SIZE_GB=32

# Plugin timeout in seconds (real analysis can take 10-30 minutes)
PLUGIN_TIMEOUT_SECONDS=600

# GeoIP lookup API (free, no key required)
GEOIP_API_URL=http://ip-api.com/json

# Allowed frontend origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Set to True for demo/development (simulates analysis with fake data)
# Set to False for real forensic analysis (requires Volatility 3)
MOCK_MODE=False
